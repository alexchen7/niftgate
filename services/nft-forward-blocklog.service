[Unit]
Description=nft-forward blocked source log collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=NFT_FORWARD_CONFIG=/etc/nft-forward/config.json
WorkingDirectory=/opt/nft-forward
ExecStart=/usr/local/bin/nft.sh run-blocklog
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
