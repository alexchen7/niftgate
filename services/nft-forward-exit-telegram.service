[Unit]
Description=nft-forward exit-node Telegram bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=NFT_FORWARD_CONFIG=/etc/nft-forward-exit/config.json
WorkingDirectory=/opt/nft-forward
ExecStart=/usr/local/bin/nft.sh run-telegram
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
